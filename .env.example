POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-local-development-password
POSTGRES_DB=llm_gateway
DATABASE_URL=postgresql+psycopg://postgres:replace-with-a-local-development-password@postgres:5432/llm_gateway
TEST_DATABASE_URL=postgresql+psycopg://postgres:replace-with-a-local-development-password@localhost:5432/llm_gateway
JWT_SECRET=replace-with-a-long-random-value
GROQ_API_KEY=
GEMINI_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GEMINI_MODEL=gemini-3.1-flash-lite
PROVIDER_TIMEOUT_SECONDS=30
FORCE_PRIMARY_FAIL=0
